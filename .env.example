# Micro.blog API Configuration
# =============================
# For posting content via Micropub API
MICROBLOG_TOKEN=your_app_token_here
MICROBLOG_API_URL=https://micro.blog/micropub

# Multi-blog destination (optional)
# If you have multiple blogs on one account, specify which one to post to
MICROBLOG_MP_DESTINATION=https://yourblog.micro.blog/

# Micro.blog Deployment Authentication
# =====================================
# For automated theme deployment via email login

# Gmail credentials for receiving sign-in emails
# IMPORTANT: Use an App Password, NOT your regular Gmail password
# Setup instructions:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (if not already enabled)
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Select app: "Mail" and device: "Other (Custom name)"
#   5. Enter name like "Micro.blog Deployment" and click Generate
#   6. Copy the 16-character password (without spaces)
GMAIL_EMAIL=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Micro.blog account email (where sign-in link is sent)
MICROBLOG_EMAIL=your.microblog.email@example.com

# Your Micro.blog site ID (find in URL when viewing site settings)
# Example: If URL is https://micro.blog/account/sites/267908/...
# then MICROBLOG_SITE_ID=267908
MICROBLOG_SITE_ID=267908

# Your theme ID (find in URL when editing theme)
# Example: If URL is https://micro.blog/account/themes/89386/...
# then MICROBLOG_THEME_ID=89386
MICROBLOG_THEME_ID=89386
